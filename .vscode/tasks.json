{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Terminal Shooter",
            "type": "shell",
            "command": "make",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Run Terminal Shooter",
            "type": "shell",
            "command": "./build/terminal_shooter.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}